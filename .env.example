# Database
DB_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql://postgres:CHANGE_ME@db:5432/platform_db?schema=public
FD_DB_PORT=15432

# Redis
REDIS_PASSWORD=CHANGE_ME
FD_REDIS_PORT=16379

# Backend
NODE_ENV=production
PORT=13001
FD_BACKEND_PORT=13001
FD_FRONTEND_PORT=18080
FD_AGENT_PORT=18000
FILE_BASE_URL=https://your-domain.com
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_FROM_JWT_SECRET
JWT_REFRESH_EXPIRES_IN=30d
ENABLE_SWAGGER=false
CORS_ORIGINS=https://admin.your-domain.com,https://m.your-domain.com
AGENT_BASE_URL=http://agent:8000
AGENT_TIMEOUT_MS=30000

# Tencent Cloud speech, optional for mobile voice input/output
TENCENT_SECRET_ID=
