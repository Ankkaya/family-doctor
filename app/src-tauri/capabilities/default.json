{
  "identifier": "default-capability",
  "description": "Default application capability",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "http://127.0.0.1:*"
        },
        {
          "url": "http://localhost:*"
        },
        {
          "url": "http://10.0.2.2:*"
        },
        {
          "url": "https://*:*"
        }
      ]
    },
    "sql:default",
    "sql:allow-execute",
    "store:default"
  ]
}
