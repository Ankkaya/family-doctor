{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "mobile-capability",
  "description": "Mobile-specific capability",
  "windows": ["main"],
  "platforms": ["iOS", "android"],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "http://127.0.0.1:*"
        },
        {
          "url": "http://localhost:*"
        },
        {
          "url": "http://10.0.2.2:*"
        },
        {
          "url": "http://192.168.1.3:*"
        },
        {
          "url": "https://*:*"
        }
      ]
    },
    "sql:default",
    "sql:allow-execute",
    "store:default"
  ]
}
