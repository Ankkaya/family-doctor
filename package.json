{
  "name": "family-doctor-platform",
  "private": true,
  "packageManager": "pnpm@10.26.2",
  "scripts": {
    "dev:infra": "docker compose up -d db redis minio",
    "dev:agent": "uv run --project agent uvicorn app.main:app --reload --host 0.0.0.0 --port 18000",
    "dev:backend": "pnpm --filter platform-template-backend start:dev",
    "dev:admin": "pnpm --filter platform-template-frontend dev",
    "dev:app": "pnpm --filter family-doctor-app dev",
    "dev:app:web": "pnpm --filter family-doctor-app web:dev",
    "build": "pnpm run build:backend && pnpm run build:admin && pnpm run build:app",
    "build:backend": "pnpm --filter platform-template-backend build",
    "build:admin": "pnpm --filter platform-template-frontend build",
    "build:app": "pnpm --filter family-doctor-app build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "api:generate": "pnpm --filter platform-template-backend openapi:generate",
    "generate:module": "node scripts/generate-module.mjs",
    "test": "pnpm run test:generator && pnpm run test:admin-utils && pnpm run test:app && pnpm run test:backend && pnpm run test:agent",
    "test:generator": "node --test scripts/generate-module.test.mjs",
    "test:admin-utils": "pnpm run test:table-columns && pnpm run test:auth-refresh",
    "test:app": "pnpm --filter family-doctor-app test",
    "test:table-columns": "node --experimental-strip-types frontend/src/utils/table-column-settings.test.mjs",
    "test:auth-refresh": "node --experimental-strip-types frontend/src/utils/auth-refresh.test.mjs",
    "test:backend": "pnpm --filter platform-template-backend test",
    "test:agent": "uv run --project agent pytest",
    "verify": "pnpm run lint && pnpm run api:generate && pnpm run build && pnpm run test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "prettier": "^3.9.1",
    "typescript-eslint": "^8.62.0",
    "vue-eslint-parser": "^10.4.1"
  }
}
