# Service
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info

# LLM Provider: openai | deepseek
LLM_PROVIDER=openai
LLM_MODEL=mimo-v2.5

# Credentials
OPENAI_API_KEY=
OPENAI_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Disclaimer shown on every response (can be overridden by NestJS if desired)
DISCLAIMER=本回复为 AI 参考建议，不构成医疗诊断。症状持续或加重请尽快就医。
